<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance><strength>10</strength><screen_edge_strength>20</screen_edge_strength></resistance>
  <focus><focusNew>yes</focusNew><followMouse>no</followMouse></focus>
  <desktops><number>4</number></desktops>
  <margins><top>0</top><bottom>28</bottom><left>0</left><right>0</right></margins>
  <theme>
  <name>Clearlooks</name>
  <titleLayout>LIMC</titleLayout> <!-- L:Logo, I:Icon, M:Maximize, C:Close -->
  <keepBorder>yes</keepBorder>
</theme>

<keyboard>
  <keybind key="A-F4"><action name="Close"/></keybind>
  <keybind key="A-Tab"><action name="NextWindow"/></keybind>
  <keybind key="W-Up"><action name="Maximize"/></keybind>
  <keybind key="W-Down"><action name="Unmaximize"/></keybind>
</keyboard>
