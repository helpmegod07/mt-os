# MT-OS Cyberpunk Theme for Openbox
# Colors
# BG: #0A0A0F, NG: #00FF88, NB: #00CCFF, NP: #FF00CC, GR: #0D1A0D

# Fonts
window.active.label.text.font: shadow=y:shadowtint=30:shadowoffset=1
window.inactive.label.text.font: shadow=n

# General
border.width: 2
padding.width: 4
padding.height: 4
window.handle.width: 4
window.client.padding.width: 1

# Active Window
window.active.border.color: #00FF88
window.active.title.bg: flat solid
window.active.title.bg.color: #0D1A0D
window.active.label.bg: parentrelative
window.active.label.text.color: #00FF88
window.active.handle.bg: flat solid
window.active.handle.bg.color: #0D1A0D
window.active.grip.bg: flat solid
window.active.grip.bg.color: #00FF88

# Inactive Window
window.inactive.border.color: #333333
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #0A0A0F
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #444444
window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #0A0A0F
window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #333333

# Buttons
window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #0D1A0D
window.active.button.unpressed.image.color: #00FF88

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #00FF88
window.active.button.hover.image.color: #0D1A0D

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #FF00CC
window.active.button.pressed.image.color: #FFFFFF

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #0A0A0F
window.inactive.button.unpressed.image.color: #444444

# Menu
menu.border.width: 2
menu.border.color: #00FF88
menu.title.bg: flat solid
menu.title.bg.color: #0D1A0D
menu.title.text.color: #00FF88
menu.items.bg: flat solid
menu.items.bg.color: #0A0A0F
menu.items.text.color: #00FF88
menu.items.active.bg: flat solid
menu.items.active.bg.color: #00FF88
menu.items.active.text.color: #0D1A0D
menu.separator.color: #00FF88
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4
